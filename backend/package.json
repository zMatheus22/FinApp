{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend FinApp",
  "main": "src/server.js",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "service:up": "docker-compose -f docker-compose.yml up -d",
    "service:down": "docker-compose -f docker-compose.yml down",
    "migrate:create": "node-pg-migrate create",
    "migrate:up": "npm run service:up && node --env-file=.env.development node_modules/node-pg-migrate/bin/node-pg-migrate up",
    "test": "node --experimental-vm-modules --env-file=.env.development node_modules/jest/bin/jest.js --watchAll",
    "dev": "npm run service:up && node --env-file=.env.development --watch src/server.js"
  },
  "keywords": [],
  "author": "Matheus Vinicyus Strada",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
